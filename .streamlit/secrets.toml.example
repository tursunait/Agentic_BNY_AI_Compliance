# Copy this to .streamlit/secrets.toml for local dev,
# or paste the contents into Streamlit Cloud → App settings → Secrets.

# URL of your deployed FastAPI backend (Railway, Render, Fly.io, etc.)
API_BASE_URL = "https://your-backend.up.railway.app"

# Optional — only needed if your backend requires auth
# BACKEND_API_KEY = "..."
