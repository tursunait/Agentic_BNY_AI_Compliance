# Database URL (fallback if SUPABASE_DB_URL is not set)
DATABASE_URL=postgresql://compliance_user:change_me@localhost:5432/compliance
# Supabase (recommended for hosted DB; overrides DATABASE_URL when set)
# SUPABASE_DB_URL=postgresql://postgres.<project_ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Or use raw components (no URL-encoding needed for password):
# SUPABASE_DB_HOST=db.<project_ref>.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=<raw-db-password>
# SUPABASE_DB_SSLMODE=require
# Supabase REST (used by KBManager for report_types and narrative_examples reads)
# SUPABASE_URL=https://<project_ref>.supabase.co
# SUPABASE_ANON_KEY=<supabase-anon-key>
# Note: if SUPABASE_DB_URL is empty and SUPABASE_URL is set to a postgres DSN, the app will use it as DB URL.

# Weaviate
# Local:
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_STARTUP_PERIOD=20
# Cloud example:
# WEAVIATE_URL=https://your-cluster.weaviate.cloud
# WEAVIATE_API_KEY=your-weaviate-api-key

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI (required for embeddings)
OPENAI_API_KEY=your-openai-key

# Gemini (optional fallback for narrative generation)
GEMINI_API_KEY=

# Testing toggle: bypass Agent 5 validator and approve directly
SKIP_VALIDATOR_FOR_TESTING=false
